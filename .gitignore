# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────
dist/
build/

# ── Environment files (NEVER commit these) ────────────────
.env
.env.local
.env.production
.env.staging
.env.*
!.env.example

# ── Uploaded files (user-generated content) ───────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── TypeScript cache ──────────────────────────────────────
*.tsbuildinfo

# ── Vite / Frontend cache ─────────────────────────────────
.vite/
frontend/.vite/

# ── PM2 ───────────────────────────────────────────────────
.pm2/
